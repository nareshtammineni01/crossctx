{
  "name": "crossctx",
  "version": "0.3.0",
  "description": "Scan microservice source code and generate cross-service API dependency maps, interactive graphs, and LLM-ready context — no config required",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "crossctx": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin/cli.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "microservices",
    "api-dependency-map",
    "service-map",
    "architecture",
    "cli",
    "code-analysis",
    "spring-boot",
    "nestjs",
    "aspnet",
    "fastapi",
    "llm-context",
    "ai",
    "openapi",
    "graph"
  ],
  "author": "Naresh Tammineni <nareshtammineni01@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nareshtammineni01/crossctx.git"
  },
  "homepage": "https://github.com/nareshtammineni01/crossctx#readme",
  "bugs": {
    "url": "https://github.com/nareshtammineni01/crossctx/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "js-yaml": "^4.1.0"
  }
}